NODE_ENV=development
PORT=4000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=mizanee

# JWT
JWT_SECRET=dev-only-change-this-to-a-long-random-secret-32chars
JWT_EXPIRES_IN=7d

# CORS — une ou plusieurs origines séparées par virgule (sans slash final)
CORS_ORIGIN=http://localhost:3000,https://mizanee.vercel.app
CLIENT_URL=http://localhost:3000

# Resend
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=noreply@mizanee.app
